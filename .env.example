SUPABASE_URL=
SUPABASE_KEY=
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
# Optional for Docker runs; defaults to "all"
LAYER=all
# Optional drift detection settings
DRIFT_CONFIDENCE_THRESHOLD=0.85
LLM_SIMILARITY_URL=
LLM_SIMILARITY_TIMEOUT=10
DRIFT_AGENT_COMMAND=

# Agent gateway
AGENT_PORT=8000

# Supabase webhook receiver
# Shared secret — must match the x-webhook-secret header set in sql/webhooks.sql
# via: ALTER DATABASE <db> SET app.webhook_secret = 'your-secret-value-here';
WEBHOOK_SECRET=
# How long (seconds) to wait after the last webhook event before triggering a
# Neo4j batch sync. Prevents a flood of per-row webhooks during bulk loads.
WEBHOOK_DEBOUNCE_SECONDS=30
# Public URL of this service — written into the Postgres GUC used by pg_net triggers:
# ALTER DATABASE <db> SET app.orchestrator_url = '<value>';
ORCHESTRATOR_URL=

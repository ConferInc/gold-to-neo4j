SUPABASE_URL=
SUPABASE_KEY=
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
# ── Realtime worker settings ─────────────────────────
NEO4J_REALTIME_WORKERS=1           # workers when running standalone
NEO4J_WORKER_BATCH_SIZE=50         # events per claim cycle
NEO4J_REALTIME_POLL_INTERVAL=5     # seconds between polls (idle)
NEO4J_WORKER_LOCK_TIMEOUT=600      # stale lock timeout (seconds) — should be ≥ 2× pg_cron cleanup interval
# Optional for Docker runs; defaults to "all"
LAYER=all

# Semantic embeddings (Python/LiteLLM - no Neo4j GenAI plugin required)
# When using LiteLLM proxy/server, set base URL (e.g. https://your-litellm-host/v1)
LITELLM_BASE_URL=
# or: OPENAI_API_BASE=
OPENAI_API_KEY=
# or: LITELLM_API_KEY= / EMBEDDING_API_TOKEN=
# Optional: EMBEDDING_MODEL=text-embedding-3-small (OpenAI model, served via LiteLLM)
# Optional: EMBEDDING_BATCH_SIZE=10 (smaller = fewer tokens/request, helps avoid 429)
# Optional: EMBEDDING_DELAY_SECONDS=5 (delay between batches)
# Optional: EMBEDDING_PRE_REQUEST_DELAY=1 (seconds to wait before each API call)
# Optional: EMBEDDING_MAX_RETRIES=20 (retries on 429)
# Optional: EMBEDDING_BACKOFF_BASE=60, EMBEDDING_BACKOFF_MAX=300 (exponential backoff)

# Optional drift detection settings
DRIFT_CONFIDENCE_THRESHOLD=0.85
LLM_SIMILARITY_URL=
LLM_SIMILARITY_TIMEOUT=10
DRIFT_AGENT_COMMAND=

# ── Embedding Pipeline ───────────────────────────────
# Controls for automated embedding generation across all paths
EMBEDDING_REALTIME_ENABLED=true     # Inline embedding after realtime upserts
EMBEDDING_BATCH_ENABLED=true        # Embedding pass after batch sync commits
EMBEDDING_BACKFILL_INTERVAL=900     # Backfill worker interval hint (seconds)

# ── GraphSAGE ────────────────────────────────────────
GRAPHSAGE_RETRAIN_CRON="0 2 */3 * *"   # Every 3 days at 2am UTC
GRAPHSAGE_INFERENCE_CRON="0 */6 * * *"  # Every 6 hours (incremental structural embeddings)
GRAPHSAGE_INFERENCE_BATCH_LIMIT=500     # Max nodes to process per inference run
